#include <iostream>
#include <cstring>
using namespace std;

class Person
{
private:
    char name[50];
    int age;

public:
    Person(const char n[], int a)
    {
        strcpy(name, n);
        age = a;
    }

    friend ostream& operator << (ostream& out,
                                 Person& p);
};

ostream& operator << (ostream& out,
                      Person& p)
{
    out << "Name: "
        << p.name
        << ", Age: "
        << p.age;

    return out;
}

int main()
{
    Person p("Alice", 30);

    cout << p;

    return 0;
}